# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — NEVER commit real .env (contains DB password + JWT secret).
# .env.example IS allowed (template only, no real secrets).
.env
.env.local
.env.*.local
.env.production
!.env.example

# SQLite local database (not used in production — Supabase is the backend)
/db/
*.db
*.db-journal

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
local-*
.claude
.z-ai-config

# logs
*.log
dev.log
dev.out.log
server.log
realtime.log
dev-startup.log

# Skills directory (internal tooling)
/skills/

# zscripts logs
/.zscripts/*.log

# Sandbox / dev environment artifacts (not part of the deployed app)
/download/
/.zscripts/
/worklog.md
/Caddyfile
/dev-startup.log
/tool-results/
/upload/
